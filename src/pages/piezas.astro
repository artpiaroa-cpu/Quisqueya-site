---
import Base from '../layouts/Base.astro'
import ProductCard from '../components/ProductCard.astro'
import { getCatalog, groupOf } from '../lib/catalog.js'

const { products, usdRate } = await getCatalog()
const piezas = products.filter(p => groupOf(p) === 'pieza')

// Nombres editoriales de cada tipo
const TYPE_LABEL = {
  'Collar Decorado': 'Collares decorativos',
  'Aplique': 'Apliques de pared',
  'Lamparas': 'Lámparas',
  'Cuadro': 'Cuadros',
  'Borlas': 'Borlas',
  'Acrilico': 'Acrílicos',
  'Decoracion Mesa': 'Decoración de mesa',
  'Jaron Decorado': 'Jarrones decorados',
  'Polimero': 'Polímero',
  'Tubos y Totem': 'Tótems',
  'Muebles': 'Muebles',
  'Alfombra': 'Alfombras',
}

const groups = new Map()
for (const p of piezas) {
  const key = TYPE_LABEL[p.type] || p.type
  if (!groups.has(key)) groups.set(key, [])
  groups.get(key).push(p)
}
const ordered = [...groups.entries()].sort((a, b) => b[1].length - a[1].length)
const slug = (s) => s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-')
---
<Base title="Piezas decorativas — Quisqueya by Piaroa" description="Collares decorativos de pared y mesa, apliques, lámparas, cuadros y esculturas de fibra natural hechas a mano en República Dominicana.">
  <div class="phero">
    <img class="phero-img" src="https://kyexrnwpybkdemlesfzf.supabase.co/storage/v1/object/public/web-images/site/piezas-hero.jpg" alt="Collar decorativo de Quisqueya by Piaroa colgado en una pared" />
    <div class="phero-veil"></div>
    <div class="wrap phero-content">
      <p class="eyebrow">Piezas decorativas</p>
      <h1>Esculturas de fibra, madera y nudo</h1>
      <p class="cat-sub">{piezas.length} piezas únicas — collares para pared o mesa, apliques, lámparas y tótems. No hay dos iguales.</p>
    </div>
  </div>

  <section class="cat-body">
    <div class="wrap">
      <div class="pills" role="navigation" aria-label="Tipos de pieza">
        {ordered.map(([name, items]) => (
          <a class="pill" href={`#${slug(name)}`}>{name} ({items.length})</a>
        ))}
      </div>

      {ordered.map(([name, items]) => (
        <div class="col-group" id={slug(name)}>
          <h2 class="col-title serif">{name} <span>{items.length}</span></h2>
          <div class="grid">
            {items.map(p => <ProductCard p={p} usdRate={usdRate} />)}
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>

<style>
  .phero {
    position: relative;
    min-height: 64svh;
    display: flex;
    align-items: center;
  }
  .phero-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: 72% center; }
  .phero-veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(43,32,20,.52) 0%, rgba(43,32,20,.22) 42%, rgba(43,32,20,0) 70%);
  }
  .phero-content { position: relative; z-index: 2; color: #fff; width: 100%; }
  .phero-content .eyebrow { color: #ecdcc5; }
  .phero-content h1 { font-size: clamp(32px, 5vw, 52px); margin: 14px 0 14px; max-width: 16ch; }
  .cat-sub { color: #f1e9dc; max-width: 44ch; }
  @media (max-width: 640px) {
    .phero { min-height: 72svh; align-items: flex-end; }
    .phero-content { padding-bottom: 40px; }
    .phero-veil { background: linear-gradient(to top, rgba(43,32,20,.68), rgba(43,32,20,.06) 60%); }
  }
  .cat-body { padding-top: 40px; }
  .col-group { margin-top: 48px; scroll-margin-top: calc(var(--nav-h) + 20px); }
  .col-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(22px, 3vw, 30px);
    margin-bottom: 22px;
  }
  .col-title span { color: var(--piedra); font-size: .6em; vertical-align: middle; margin-left: 8px; }
</style>
