---
import Base from '../../layouts/Base.astro'
import ProductCard from '../../components/ProductCard.astro'
import {
  getCatalog, groupOf, codeSlug, displayName, cleanCollection,
  fmtRD, fmtUSD, waProductLink,
} from '../../lib/catalog.js'

export async function getStaticPaths() {
  const { products, usdRate } = await getCatalog()
  return products.map(p => {
    const group = groupOf(p)
    // Relacionadas: mismo tipo primero, luego mismo grupo; nunca la misma pieza.
    const sameType = products.filter(x => x.code !== p.code && x.type === p.type)
    const sameGroup = products.filter(x => x.code !== p.code && x.type !== p.type && groupOf(x) === group)
    const related = [...sameType, ...sameGroup].slice(0, 4)
    return { params: { code: codeSlug(p) }, props: { p, usdRate, related } }
  })
}

const { p, usdRate, related } = Astro.props
const name = displayName(p)
const col = cleanCollection(p.collection)
const group = groupOf(p)
const wa = waProductLink(p, usdRate)
const lastOne = Number(p.stock_quisqueya) === 1

const GROUP_PAGE = { aroma: ['/velas', 'Velas y aromas'], cojin: ['/cojines', 'Cojines'], pieza: ['/piezas', 'Piezas decorativas'] }
const [groupHref, groupLabel] = GROUP_PAGE[group]

const title = `${name} · ${p.code} — Quisqueya by Piaroa`
const description = (p.description && p.description.trim())
  || `${p.type} hecha a mano en República Dominicana. ${name} — pieza única disponible en nuestro showroom de Santo Domingo.`

const images = [p.web_image_url, p.web_image_url_2].filter(Boolean)
const canonical = new URL(Astro.url.pathname, Astro.site).href

const productLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name,
  sku: p.code,
  image: images,
  description,
  brand: { '@type': 'Brand', name: 'Quisqueya by Piaroa' },
  offers: {
    '@type': 'Offer',
    url: canonical,
    price: Number(p.price_sale || 0),
    priceCurrency: 'DOP',
    availability: 'https://schema.org/InStock',
    itemCondition: 'https://schema.org/NewCondition',
    seller: { '@type': 'Organization', name: 'Quisqueya by Piaroa' },
  },
}
---
<Base title={title} description={description} image={images[0]} jsonLd={productLd}>
  <section class="ficha">
    <div class="wrap">
      <nav class="crumbs" aria-label="Ruta">
        <a href="/">Inicio</a><span>/</span><a href={groupHref}>{groupLabel}</a><span>/</span><span class="crumb-here">{p.code}</span>
      </nav>

      <div class="ficha-grid">
        <div class="gallery">
          <div class="ph main">
            <img src={p.web_image_url} alt={name} width="900" height="1200" fetchpriority="high" />
            {lastOne && <span class="badge">Última pieza</span>}
          </div>
          {p.web_image_url_2 && (
            <div class="ph">
              <img src={p.web_image_url_2} alt={`${name} — en ambiente`} width="900" height="1200" loading="lazy" />
            </div>
          )}
        </div>

        <div class="info">
          <p class="eyebrow">{col ? `${p.type} · ${col}` : p.type}</p>
          <h1>{name}</h1>
          <p class="code">Ref. {p.code}</p>

          <p class="price">
            <strong>{fmtRD(p.price_sale)}</strong>
            <span class="usd">{fmtUSD(p.price_sale, usdRate)}</span>
          </p>
          {p.dimensions && <p class="dims">Medidas: {p.dimensions}</p>}

          <p class="desc">{description}</p>

          <div class="unica">
            <p><strong>Pieza única, hecha a mano.</strong> Está físicamente en nuestro showroom de Santo Domingo — si la ves aquí, está disponible.</p>
          </div>

          <div class="ctas">
            <a class="btn btn-solid" href={wa} target="_blank" rel="noopener">Consultar por WhatsApp</a>
            <a class="btn btn-ghost" href={groupHref}>Ver más {groupLabel.toLowerCase()}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {related.length > 0 && (
    <section class="rel">
      <div class="wrap">
        <div class="sec-head">
          <p class="eyebrow">También en el showroom</p>
          <h2>Piezas que conversan con esta</h2>
        </div>
        <div class="grid">
          {related.map(r => <ProductCard p={r} usdRate={usdRate} />)}
        </div>
      </div>
    </section>
  )}
</Base>

<style>
  .ficha { padding-top: 34px; }
  .crumbs {
    display: flex;
    gap: 10px;
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: .06em;
    color: var(--piedra);
    margin-bottom: 26px;
    text-transform: uppercase;
  }
  .crumbs a:hover { color: var(--terracota); }
  .crumb-here { color: var(--tinta-2); }

  .ficha-grid {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: clamp(28px, 4vw, 64px);
    align-items: start;
  }
  @media (max-width: 860px) { .ficha-grid { grid-template-columns: 1fr; } }

  .gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .gallery:has(.ph:only-child) { grid-template-columns: 1fr; }
  @media (max-width: 560px) { .gallery { grid-template-columns: 1fr; } }
  .ph {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--arena);
    box-shadow: var(--card-shadow);
    aspect-ratio: 3 / 4;
  }
  .ph img { width: 100%; height: 100%; object-fit: cover; }
  .badge {
    position: absolute;
    top: 14px;
    left: 14px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
    background: var(--marfil);
    color: var(--tinta);
    padding: 6px 12px;
    border-radius: 999px;
  }

  .info { position: sticky; top: calc(var(--nav-h) + 60px); }
  .info .eyebrow { color: var(--terracota); }
  .info h1 { font-size: clamp(28px, 4vw, 44px); margin: 12px 0 6px; }
  .code { font-size: 13px; color: var(--piedra); letter-spacing: .08em; }
  .price { margin: 22px 0 4px; display: flex; align-items: baseline; gap: 12px; }
  .price strong { font-size: 26px; font-weight: 800; }
  .price .usd { color: var(--tinta-2); font-size: 16px; }
  .dims { font-size: 14.5px; color: var(--tinta-2); }
  .desc { margin: 20px 0; color: var(--tinta-2); max-width: 46ch; }
  .unica {
    background: var(--arena);
    border-radius: var(--radius);
    padding: 16px 18px;
    font-size: 14px;
    color: var(--tinta-2);
    max-width: 46ch;
  }
  .unica strong { color: var(--tinta); }
  .ctas { display: flex; gap: 12px; margin-top: 26px; flex-wrap: wrap; }

  .rel { background: var(--marfil); border-top: 1px solid var(--linea); }
</style>
