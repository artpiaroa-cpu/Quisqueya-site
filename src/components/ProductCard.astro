---
import { fmtRD, fmtUSD, cleanCollection, displayName, codeSlug } from '../lib/catalog.js'

const { p, usdRate } = Astro.props
const href = `/p/${codeSlug(p)}`
const col = cleanCollection(p.collection)
const name = displayName(p)
const lastOne = Number(p.stock_quisqueya) === 1
---
<article class="card">
  <a class="photo" href={href} aria-label={`Ver ${name}`}>
    <img src={p.web_image_url} alt={name} loading="lazy" />
    {p.web_image_url_2 && <img class="alt" src={p.web_image_url_2} alt="" loading="lazy" aria-hidden="true" />}
    {lastOne && <span class="badge">Última pieza</span>}
  </a>
  <div class="info">
    <p class="type">{col ? `${p.type} · ${col}` : p.type}</p>
    <h3 class="name"><a href={href}>{name}</a></h3>
    <p class="price">
      <strong>{fmtRD(p.price_sale)}</strong>
      <span>{fmtUSD(p.price_sale, usdRate)}</span>
      {p.dimensions && <span class="dim">· {p.dimensions}</span>}
    </p>
  </div>
</article>

<style>
  .card { display: flex; flex-direction: column; }
  .photo {
    position: relative;
    display: block;
    aspect-ratio: 3 / 4;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--arena);
    box-shadow: var(--card-shadow);
    transition: box-shadow .2s ease;
  }
  .photo:hover { box-shadow: var(--card-shadow-hover); }
  .photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity .35s ease;
  }
  .photo .alt { opacity: 0; }
  .photo:hover .alt { opacity: 1; }
  .badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
    background: var(--marfil);
    color: var(--tinta);
    padding: 6px 12px;
    border-radius: 999px;
  }
  /* texto centrado bajo la foto (estética Angela Maria) */
  .info { padding: 14px 6px 0; text-align: center; }
  .type {
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--piedra);
  }
  .name {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 17px;
    line-height: 1.35;
    margin: 5px 0 7px;
  }
  .price { font-size: 14px; color: var(--tinta-2); display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; }
  .price strong { color: var(--tinta); font-weight: 800; }
  .dim { color: var(--piedra); }
</style>
